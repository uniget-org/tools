#syntax=docker/dockerfile:1.25.0@sha256:0adf442eae370b6087e08edc7c50b552d80ddf261576f4ebd6421006b2461f12

FROM ghcr.io/uniget-org/tools/node-lts:latest AS node

FROM registry.gitlab.com/uniget-org/images/ubuntu:26.04@sha256:8fc1cc1ba5dd196bd42790880931d3d76985c2a94ec55e8095615331dfd3b580 AS prepare
COPY --from=ghcr.io/uniget-org/tools/uniget-build:latest \
    /etc/profile.d/ \
    /etc/profile.d/
SHELL [ "bash", "-clo", "errexit" ]
ARG name
ARG version
COPY --link --from=node / /usr/local/
WORKDIR /uniget_bootstrap/libexec/opencode
ARG name
ARG version
RUN <<EOF
npm install \
    --omit=dev \
    "opencode-ai@${version}"
ln --symbolic --relative --force "${prefix}/libexec/opencode/node_modules/.bin/opencode" "${prefix}/bin/"
EOF