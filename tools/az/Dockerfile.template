#syntax=docker/dockerfile:1.24.0@sha256:87999aa3d42bdc6bea60565083ee17e86d1f3339802f543c0d03998580f9cb89

FROM ghcr.io/uniget-org/tools/python-3.12:latest AS python
FROM ghcr.io/uniget-org/tools/pipx:latest AS pipx

FROM registry.gitlab.com/uniget-org/images/build-essential:26.04@sha256:32604fa3469f3a542fa40f9a78e330702400db71c3f020a8d5daf352e1fd8833 AS prepare
COPY --from=ghcr.io/uniget-org/tools/uniget-build:latest \
    /etc/profile.d/ \
    /etc/profile.d/
SHELL [ "bash", "-clo", "errexit" ]
COPY --link --from=python / /usr/local/
COPY --link --from=pipx / /usr/local/
ARG name
ARG version
RUN --mount=type=cache,target=/root/.cache/pip <<EOF
export PIPX_HOME="${prefix}/libexec/pipx"
pipx install "azure-cli==${version}"
pipx-fix-venv-pyvenv-cfg azure-cli

ln --symbolic --relative --force "${prefix}/libexec/pipx/venvs/azure-cli/bin/az" "${prefix}/bin/az"
ln --symbolic --relative --force "${prefix}/bin/python3" "${prefix}/libexec/pipx/venvs/azure-cli/bin/python3.12"

mv "${prefix}/libexec/pipx/venvs/azure-cli/bin/az" "${prefix}/libexec/pipx/venvs/azure-cli/bin/az.go-template"
sed -i "s|#\!${prefix}|#\!{{ .Target }}|" "${prefix}/libexec/pipx/venvs/azure-cli/bin/az.go-template"
EOF