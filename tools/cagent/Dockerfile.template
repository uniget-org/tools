#syntax=docker/dockerfile:1.22.0@sha256:4a43a54dd1fedceb30ba47e76cfcf2b47304f4161c0caeac2db1c61804ea3c91

FROM registry.gitlab.com/uniget-org/images/ubuntu:24.04 AS prepare
COPY --from=ghcr.io/uniget-org/tools/uniget-build:latest \
    /etc/profile.d/ \
    /etc/profile.d/
SHELL [ "bash", "-clo", "errexit" ]
ARG name
ARG version
RUN --mount=type=cache,target=/var/cache/uniget/download <<EOF
url="https://github.com/docker/cagent/releases/download/v${version}/cagent-linux-${alt_arch}"
filename="$( basename "${url}" )"

check-github-release-asset "docker/cagent" "v${version}" "${filename}"
curl --silent --show-error --location --fail --output "${uniget_cache_download}/${filename}" \
    "${url}"

install --mode=0755 \
    "${uniget_cache_download}/${filename}" \
    "${prefix}/bin/cagent"
EOF
RUN <<EOF
"${prefix}/bin/cagent" completion bash >"${prefix}/share/bash-completion/completions/cagent"
"${prefix}/bin/cagent" completion fish >"${prefix}/share/fish/vendor_completions.d/cagent.fish"
"${prefix}/bin/cagent" completion zsh >"${prefix}/share/zsh/vendor-completions/_cagent"
EOF