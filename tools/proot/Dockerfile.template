#syntax=docker/dockerfile:1.24.0@sha256:2780b5c3bab67f1f76c781860de469442999ed1a0d7992a5efdf2cffc0e3d769

FROM ghcr.io/uniget-org/tools/make:latest AS make

FROM registry.gitlab.com/uniget-org/images/build-base:3.23@sha256:b3f7e2f78a9eda4260453779505b7054d137bf5c136dead92fc8e9240eb00835 AS prepare
COPY --from=ghcr.io/uniget-org/tools/uniget-build:latest \
    /etc/profile.d/ \
    /etc/profile.d/
SHELL [ "bash", "-clo", "errexit" ]
ARG name
ARG version
RUN --mount=type=cache,target=/var/cache/apk <<EOF
apk add --update-cache \
    talloc-dev \
    talloc-static \
    linux-headers \
    bsd-compat-headers \
    py3-docutils
EOF
COPY --link --from=make / /usr/local/
WORKDIR /tmp/proot
RUN <<EOF
git clone -q --config advice.detachedHead=false --depth 1 --branch "v${version}" https://github.com/proot-me/proot .
cat <<EOP | patch -p0
--- src/cli/cli.c.orig
+++ src/cli/cli.c
@@ -22,6 +22,7 @@

 #include <stdio.h>         /* printf(3), */
 #include <stdbool.h>       /* bool, true, false,  */
+#include <libgen.h>
 #include <linux/limits.h>  /* ARG_MAX, PATH_MAX, */
 #include <string.h>        /* str*(3), basename(3),  */
 #include <talloc.h>        /* talloc*,  */
EOP
make -C src -j$(nproc) LDFLAGS="-static -ltalloc"
make -C doc proot/man.1
cp src/proot "${prefix}/bin/"
cp doc/proot/man.1 "${prefix}/share/man/man1/proot.1"
EOF